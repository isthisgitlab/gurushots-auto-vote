{
    "name": "gurushots-auto-vote",
    "version": "1.1.6",
    "description": "GuruShots Auto Vote - An Electron application for automated voting on GuruShots challenges with unified GUI and CLI interfaces (supports both real and mock modes)",
    "main": "src/js/index.js",
    "scripts": {
        "build": "cross-env NODE_ENV=production electron-builder",
        "build:all": "pnpm run build:prep && cross-env NODE_ENV=production electron-builder -mwl",
        "build:cli:all": "node scripts/build-cli.js",
        "build:cli:linux": "node scripts/build-cli.js gurucli-linux",
        "build:cli:linux-arm": "node scripts/build-cli.js gurucli-linux-arm",
        "build:cli:mac": "node scripts/build-cli.js gurucli-mac",
        "build:css": "tailwindcss -i ./src/styles/styles.css -o ./dist/styles.css --minify",
        "build:react": "node scripts/build-react.js",
        "build:prep": "pnpm run build:css && pnpm run build:react",
        "build:site": "pnpm run build:site:html && pnpm run build:site:css",
        "build:site:html": "node scripts/build-site.js",
        "build:site:css": "tailwindcss -i ./scripts/site/site.css -o ./dist-site/styles.css --minify",
        "build:android": "cross-env NODE_ENV=production pnpm run build:prep && pnpm exec cap sync android && cd android && ./gradlew assembleRelease",
        "android:open": "pnpm exec cap open android",
        "build:linux": "pnpm run build:prep && cross-env NODE_ENV=production electron-builder --linux",
        "build:linux-arm": "pnpm run build:prep && cross-env NODE_ENV=production electron-builder --linux --arm64",
        "build:mac": "pnpm run build:prep && cross-env NODE_ENV=production electron-builder --mac",
        "build:win": "pnpm run build:prep && cross-env NODE_ENV=production electron-builder --win",
        "bump": "pnpm dlx npm-check-updates -u && pnpm install",
        "cleanup:logs": "node scripts/cleanup-logs.js",
        "cli:help": "node src/js/cli/cli.js help",
        "cli:login": "node src/js/cli/cli.js login",
        "cli:reset-windows": "node src/js/cli/cli.js reset-windows",
        "cli:start": "node src/js/cli/cli.js start",
        "cli:status": "node src/js/cli/cli.js status",
        "cli:vote": "node src/js/cli/cli.js vote",
        "dev": "concurrently --kill-others-on-fail \"pnpm run watch:css\" \"pnpm run watch:react\" \"electronmon .\"",
        "dev:no-watch": "concurrently --kill-others \"pnpm run watch:css\" \"pnpm run start\"",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "gui:refresh": "echo 'If the GUI is running, refresh it manually (Cmd+R / Ctrl+R) to apply CLI settings changes.'",
        "knip": "knip",
        "lint": "pnpm run syntax:check && eslint src/ scripts/",
        "lint:fix": "eslint src/ scripts/ --fix",
        "syntax:check": "node scripts/syntax-check.js",
        "preinstall": "only-allow pnpm",
        "prebuild": "pnpm run build:prep",
        "prepare": "lefthook install",
        "settings:get": "node scripts/settings-cli.js get",
        "settings:global-defaults": "node scripts/settings-cli.js global-defaults",
        "settings:help": "node scripts/settings-cli.js help",
        "settings:reset": "node scripts/settings-cli.js reset",
        "settings:reset-all": "node scripts/settings-cli.js reset-all",
        "settings:reset-global": "node scripts/settings-cli.js reset-global",
        "settings:schema": "node scripts/settings-cli.js schema",
        "settings:set": "node scripts/settings-cli.js set",
        "settings:set-global": "node scripts/settings-cli.js set-global",
        "size": "cross-env NODE_ENV=production pnpm run build:react && size-limit",
        "size:cli": "node scripts/check-cli-size.js",
        "start": "electron .",
        "tag": "git tag v$(node -p \"require('./package.json').version\")",
        "tag:push": "pnpm run tag && git push origin v$(node -p \"require('./package.json').version\")",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit",
        "update:readme": "node scripts/readme-version.js",
        "verify:readme": "node scripts/readme-version.js --check",
        "watch:css": "tailwindcss -i ./src/styles/styles.css -o ./dist/styles.css --watch",
        "watch:react": "node scripts/build-react.js --watch"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/isthisgitlab/gurushots-auto-vote.git"
    },
    "keywords": [],
    "author": {
        "name": "isthisgitlab",
        "email": "isthisgitlab@isthisgitlab.com"
    },
    "license": "ISC",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/isthisgitlab/gurushots-auto-vote/issues"
    },
    "homepage": "https://github.com/isthisgitlab/gurushots-auto-vote#readme",
    "engines": {
        "node": ">=26.0.0",
        "pnpm": ">=11.0.0"
    },
    "packageManager": "pnpm@11.3.0",
    "dependencies": {
        "@capacitor/android": "^8.3.4",
        "@capacitor/core": "^8.3.4",
        "@capacitor/preferences": "^8.0.1",
        "@capawesome-team/capacitor-android-foreground-service": "^8.1.0",
        "@preact/signals": "^2.9.1",
        "axios": "^1.16.1",
        "electron-updater": "^6.8.6",
        "preact": "^10.29.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.3.4",
        "@eslint/js": "^10.0.1",
        "@happy-dom/jest-environment": "^20.9.0",
        "@jest/globals": "^30.4.1",
        "@size-limit/file": "^12.1.0",
        "@swc/jest": "^0.2.39",
        "@tailwindcss/cli": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/preact": "^3.2.4",
        "@types/node": "^25.9.1",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "daisyui": "^5.5.20",
        "electron": "^42.2.0",
        "electron-builder": "^26.11.1",
        "electronmon": "^2.0.4",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "jest-environment-node": "^30.4.1",
        "knip": "^6.14.2",
        "lefthook": "^2.1.8",
        "marked": "^18.0.4",
        "marked-gfm-heading-id": "^4.1.4",
        "only-allow": "^1.2.2",
        "postject": "1.0.0-alpha.6",
        "prettier": "4.0.0-alpha.13",
        "size-limit": "^12.1.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    },
    "electronmon": {
        "patterns": [
            "!dist/**",
            "!build/**",
            "!coverage/**",
            "!.cache/**",
            "!tests/**",
            "!docs/**",
            "!android/**",
            "!logs/**",
            "!scripts/**",
            "!**/*.test.js",
            "!**/*.test.jsx"
        ]
    },
    "build": {
        "appId": "com.gurushots.autovote",
        "productName": "GuruShotsAutoVote",
        "compression": "maximum",
        "removePackageScripts": true,
        "removePackageKeywords": true,
        "files": [
            "dist/**/*",
            "src/html/**/*",
            "src/js/**/*",
            "src/assets/**/*",
            "package.json"
        ],
        "directories": {
            "output": "build"
        },
        "mac": {
            "category": "public.app-category.utilities",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                },
                {
                    "target": "dir",
                    "arch": [
                        "arm64"
                    ]
                }
            ],
            "icon": "src/assets/logo.png",
            "gatekeeperAssess": false,
            "hardenedRuntime": false,
            "artifactName": "GuruShotsAutoVote-v${version}-${arch}.${ext}"
        },
        "win": {
            "target": "portable",
            "icon": "src/assets/logo.png",
            "artifactName": "GuruShotsAutoVote-v${version}-${arch}.exe"
        },
        "linux": {
            "target": "AppImage",
            "category": "Utility",
            "icon": "src/assets/logo.png",
            "maintainer": "isthisgitlab@isthisgitlab.com",
            "artifactName": "GuruShotsAutoVote-v${version}-${arch}.AppImage"
        },
        "publish": {
            "provider": "github",
            "releaseType": "release"
        }
    },
    "jest": {
        "projects": [
            {
                "displayName": "node",
                "testEnvironment": "node",
                "roots": [
                    "<rootDir>/src",
                    "<rootDir>/tests"
                ],
                "setupFilesAfterEnv": [
                    "<rootDir>/tests/setup.js"
                ],
                "testMatch": [
                    "**/__tests__/**/*.js",
                    "**/?(*.)+(spec|test).js"
                ],
                "transform": {
                    "\\.[jt]sx?$": [
                        "@swc/jest",
                        {
                            "jsc": {
                                "parser": {
                                    "syntax": "ecmascript",
                                    "jsx": true
                                },
                                "transform": {
                                    "react": {
                                        "runtime": "automatic",
                                        "importSource": "preact"
                                    }
                                }
                            }
                        }
                    ]
                },
                "moduleNameMapper": {
                    "^@/(.*)$": "<rootDir>/src/js/react/$1",
                    "^react$": "preact/compat",
                    "^react-dom$": "preact/compat",
                    "^react-dom/client$": "preact/compat/client",
                    "^react/jsx-runtime$": "preact/jsx-runtime",
                    "^react/jsx-dev-runtime$": "preact/jsx-dev-runtime"
                }
            },
            {
                "displayName": "happy-dom",
                "testEnvironment": "@happy-dom/jest-environment",
                "testEnvironmentOptions": {
                    "customExportConditions": [
                        "node"
                    ]
                },
                "roots": [
                    "<rootDir>/tests/react"
                ],
                "setupFilesAfterEnv": [
                    "<rootDir>/tests/setup.js",
                    "<rootDir>/src/js/react/test/setup.js"
                ],
                "testMatch": [
                    "**/?(*.)+(spec|test).jsx"
                ],
                "transform": {
                    "\\.[jt]sx?$": [
                        "@swc/jest",
                        {
                            "jsc": {
                                "parser": {
                                    "syntax": "ecmascript",
                                    "jsx": true
                                },
                                "transform": {
                                    "react": {
                                        "runtime": "automatic",
                                        "importSource": "preact"
                                    }
                                }
                            }
                        }
                    ]
                },
                "moduleNameMapper": {
                    "^@/(.*)$": "<rootDir>/src/js/react/$1",
                    "^react$": "preact/compat",
                    "^react-dom$": "preact/compat",
                    "^react-dom/client$": "preact/compat/client",
                    "^react/jsx-runtime$": "preact/jsx-runtime",
                    "^react/jsx-dev-runtime$": "preact/jsx-dev-runtime"
                }
            }
        ],
        "collectCoverage": false,
        "collectCoverageFrom": [
            "src/js/api/**/*.js",
            "src/js/apiFactory.js",
            "src/js/ipc/**/*.js",
            "src/js/metadata.js",
            "src/js/services/VotingLogic.js",
            "src/js/services/manualVote.js",
            "src/js/settings.js",
            "src/js/settings/**/*.js"
        ],
        "coverageDirectory": "coverage",
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 60,
                "functions": 60,
                "lines": 60,
                "statements": 60
            }
        }
    }
}
