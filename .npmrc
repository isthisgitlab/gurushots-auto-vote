# pnpm reads `.npmrc` for its own configuration.
# `auto-install-peers` lets pnpm resolve unlisted peer deps automatically. Combined with
# a committed `pnpm-lock.yaml` and `--frozen-lockfile` in CI, the install is reproducible;
# the convenience is contained to first-time / dependency-update flows.
auto-install-peers=true
# Fail fast on conflicting peer ranges rather than silently picking a winner.
strict-peer-dependencies=true
# Honor the `engines` field in package.json (pinned to Node 26+, pnpm 11.7+).
engine-strict=true
